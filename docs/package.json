{
  "name": "chatroom-docs",
  "private": true,
  "type": "module",
  "version": "3.0.0",
  "scripts": {
    "docs:dev": "vitepress dev .",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview .",
    "docs:serve": "vitepress serve .",
    "optimize": "node scripts/optimize.mjs",
    "lint:md": "markdownlint-cli2 '**/*.md' --config .markdownlint.json",
    "lint:links": "lychee . --config lychee.toml",
    "analyze": "node scripts/analyze.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "sharp": "^0.34.5",
    "vitepress": "^1.6.4"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
