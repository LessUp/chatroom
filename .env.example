# ChatRoom 环境变量示例
# 这是配置模板与说明清单；应用本身不会自动加载 .env 文件
# 运行 go run ./cmd/server 时，服务读取的是进程环境变量

# HTTP 端口
APP_PORT=8080

# 运行环境（dev / staging / production）
APP_ENV=dev

# PostgreSQL 连接串
DATABASE_DSN=host=localhost user=postgres password=postgres dbname=chatroom port=5432 sslmode=disable TimeZone=UTC

# JWT 签名密钥（非 dev 环境必须修改）
JWT_SECRET=dev-secret-change-me

# 允许的前端来源列表（非 dev 环境下用于 CORS / WebSocket 来源校验）
# 多个值用逗号分隔；必须写完整 origin，例如 https://chat.example.com
ALLOWED_ORIGINS=

# Access Token 有效期（分钟）
ACCESS_TOKEN_TTL_MINUTES=15

# Refresh Token 有效期（天）
REFRESH_TOKEN_TTL_DAYS=7

# WebSocket 票据有效期（秒）
WS_TICKET_TTL_SECONDS=60

# 实例标识（用于多实例场景）
APP_INSTANCE_ID=local

# 日志级别：trace / debug / info / warn / error / fatal
LOG_LEVEL=info

# 日志格式：console / json
LOG_FORMAT=console

# WebSocket 消息最大字节数（默认 1MB）
WS_MAX_MESSAGE_SIZE=1048576

# WebSocket 消息内容最大字符数（默认 2000）
WS_MAX_CONTENT_SIZE=2000

# 数据库连接池：最大空闲连接数
DB_MAX_IDLE_CONNS=5

# 数据库连接池：最大打开连接数
DB_MAX_OPEN_CONNS=20
