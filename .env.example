# ChatRoom 环境变量示例
# 复制此文件为 .env 并按需修改

# HTTP 端口
APP_PORT=8080

# 运行环境（dev / staging / production）
APP_ENV=dev

# PostgreSQL 连接串
DATABASE_DSN=host=localhost user=postgres password=postgres dbname=chatroom port=5432 sslmode=disable TimeZone=UTC

# JWT 签名密钥（非 dev 环境必须修改）
JWT_SECRET=dev-secret-change-me

# 允许的前端来源列表（生产环境可选，多个值用逗号分隔；未设置时仅允许严格同源）
ALLOWED_ORIGINS=

# Access Token 有效期（分钟）
ACCESS_TOKEN_TTL_MINUTES=15

# Refresh Token 有效期（天）
REFRESH_TOKEN_TTL_DAYS=7

# 日志级别：trace / debug / info / warn / error / fatal
LOG_LEVEL=info

# 日志格式：console / json
LOG_FORMAT=console
