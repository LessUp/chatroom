{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "preview": "vite preview",
    "test": "tsc -p tsconfig.test.json && node -e \"require('node:fs').mkdirSync('.test-dist',{recursive:true});require('node:fs').writeFileSync('.test-dist/package.json', JSON.stringify({type:'commonjs'}));\" && node --test .test-dist/storage.test.js",
    "test:watch": "tsc -p tsconfig.test.json && node -e \"require('node:fs').mkdirSync('.test-dist',{recursive:true});require('node:fs').writeFileSync('.test-dist/package.json', JSON.stringify({type:'commonjs'}));\" && node --test --watch .test-dist/storage.test.js",
    "test:coverage": "npm run test"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^1.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "npm:rolldown-vite@7.2.5",
    "vitest": "^1.3.1"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.5"
  }
}
